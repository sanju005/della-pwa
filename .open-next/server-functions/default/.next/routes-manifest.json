      "page": "/api/provider/register/[id]",
      "regex": "^/api/provider/register/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/provider/register/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/provider/dashboard/[id]",
